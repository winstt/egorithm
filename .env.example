# Copy to .env and fill in. Never commit .env (it's gitignored).
# Used by scripts/ingest-r2.mjs to back the full IG archive into Cloudflare R2.

# Instagram Graph API (Facebook Login) — same values as the GitHub secrets
IG_BUSINESS_ID=17841470673507793
IG_PAGE_TOKEN=

# Cloudflare R2 — from Dashboard → R2 → Manage R2 API Tokens → create token
# (Object Read & Write). The token page shows all three:
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional
R2_BUCKET=egorithm-media
# MAX_POSTS=50      # uncomment for a small trial run first
# THUMBS=1          # also upload ~600px thumbnails
# CONCURRENCY=8
