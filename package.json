{
  "name": "egorithm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "sync": "node scripts/sync.mjs",
    "publish:queue": "node scripts/publish.mjs",
    "ingest:r2": "node --env-file=egorithm.env scripts/ingest-r2.mjs",
    "thumbs:r2": "node --env-file=egorithm.env scripts/thumbs-r2.mjs"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1091.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
